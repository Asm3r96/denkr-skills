{
  "name": "journey-logbook",
  "display_name": "Journey Logbook",
  "description": "Create or reuse a journey, then save timeline-style logs into it using Denkr's built-in journey tools.",
  "version": "0.1.0",
  "capabilities": [
    "journey-create",
    "journey-reuse",
    "journey-log-create",
    "journey-log-list"
  ],
  "permissions": {
    "tool_names": [
      "journey.list",
      "journey.get",
      "journey.create",
      "journey.update",
      "journey.log.create",
      "journey.log.list"
    ]
  }
}
